# ─────────────────────────────────────────────────────────────────────────────
# SimpSec — Environment Variables
# Copy this file to .env (local dev) or configure these in your hosting
# platform's environment/secret settings.  NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Salesforce Connected App credentials ─────────────────────────────────────
# Create a Connected App in Salesforce Setup > App Manager.
# Enable OAuth, set grant types to "Password" (Username-Password Flow).
# Copy the Consumer Key and Consumer Secret here.
SF_CLIENT_ID=your_connected_app_consumer_key
SF_CLIENT_SECRET=your_connected_app_consumer_secret

# ── Salesforce API user credentials ──────────────────────────────────────────
# Use a dedicated integration user with the minimum required permissions
# (create Leads). Do NOT use your personal admin account.
SF_USERNAME=api-user@yourorg.com
SF_PASSWORD=your_salesforce_password

# ── Salesforce security token ─────────────────────────────────────────────────
# Found in Salesforce: My Settings > Personal > Reset My Security Token.
# Append it to SF_PASSWORD in the token request (the endpoint does this automatically).
SF_SECURITY_TOKEN=your_security_token

# ── CORS origin ──────────────────────────────────────────────────────────────
# The domain the static site is served from. The /api/lead endpoint only
# accepts cross-origin requests from this origin.
ALLOWED_ORIGIN=https://simpsec.wasmer.app
